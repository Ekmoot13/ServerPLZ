# .env.prod.example — szablon zmiennych produkcyjnych (Etap 0)
#
# Skopiuj do pliku .env w katalogu głównym repo i uzupełnij WŁASNYMI wartościami.
# NIGDY nie commituj pliku .env (jest w .gitignore).
#
#   cp deploy/.env.prod.example .env
#   # następnie wygeneruj sekrety i wpisz domenę (patrz komentarze niżej)

# --- Domena ---
# Domena bez http/https. Rekordy A dla DOMAIN oraz api.DOMAIN muszą wskazywać na IP serwera.
DOMAIN=staging.twojadomena.pl

# --- PostgreSQL ---
POSTGRES_DB=plz
POSTGRES_USER=plz_user
# Wygeneruj silne hasło, np.:  openssl rand -base64 24
POSTGRES_PASSWORD=ZMIEN_MNIE_silne_haslo

# --- Backend ---
# Klucz do podpisywania tokenów JWT. Wygeneruj, np.:  openssl rand -hex 32
SECRET_KEY=ZMIEN_MNIE_min_32_znaki_losowe
